###############################################################################
# Dockerfile.dev — React (Vite) Development Build
# Hot-reload enabled for local development
###############################################################################

FROM node:20-alpine

WORKDIR /app

COPY package.json package-lock.json* ./
RUN npm ci --prefer-offline --no-audit

COPY . .

EXPOSE 3000

CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0", "--port", "3000"]
